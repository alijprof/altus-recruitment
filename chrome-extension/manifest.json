{
  "manifest_version": 3,
  "name": "Altus — LinkedIn capture",
  "version": "0.1.7",
  "description": "Capture a LinkedIn profile into the Altus CRM with one click.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://altusrecruit.com/*",
    "https://www.altusrecruit.com/*",
    "https://altus-recruitment.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "src/background/ingest.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Capture this LinkedIn profile"
  }
}
