# Copy to .env.local and fill in the values.

# --- Supabase ---------------------------------------------------------------
# Local dev: `pnpm exec supabase start` prints these values.
# Cloud: from Supabase project settings → API.
#
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is the browser-exposed key (formerly
# called "anon key"). It is safe to ship to the client because RLS is the
# real boundary.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Never exposed to the browser. Used by background jobs and
# admin actions that need to bypass RLS (Task 4+).
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic Claude ------------------------------------------------------
# All Claude calls go through src/lib/ai/claude.ts. Keys must start with
# `sk-ant-`. Cost is logged per tenant to ai_usage on every call.
ANTHROPIC_API_KEY=

# --- Inngest ---------------------------------------------------------------
# Background job runner for long-running AI tasks (CV parsing, batch
# matching). Get keys from https://app.inngest.com after creating an app.
# In local dev the Inngest CLI provides safe defaults — see README.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Sentry ----------------------------------------------------------------
# Error tracking. SENTRY_DSN is the server DSN, NEXT_PUBLIC_SENTRY_DSN is
# the browser DSN (typically the same value). SENTRY_AUTH_TOKEN is used at
# build time to upload source maps; leave blank in local dev.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- E2E only --------------------------------------------------------------
# Set to "1" in local/dev to enable the password sign-in fallback at
# /sign-in?password=1. Used by the Playwright global-setup to sign in as the
# deterministic seed owner without intercepting a magic-link email. Leave
# unset in production — production sign-in is always magic-link.
NEXT_PUBLIC_ALLOW_PASSWORD_AUTH=
