# Copy to .env.local and fill in the values.

# --- Supabase ---------------------------------------------------------------
# Local dev: `pnpm exec supabase start` prints these values.
# Cloud: from Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never exposed to the browser. Used by background jobs and
# admin actions that need to bypass RLS (Task 4+).
SUPABASE_SERVICE_ROLE_KEY=
